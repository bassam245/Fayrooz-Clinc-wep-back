{
  "version": 2,
  "buildCommand": "pnpm install && pnpm run build",
  "installCommand": "pnpm install",
  "builds": [
    {
      "src": "dist",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "(.*)",
      "dest": "src/app.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "SESSION_SECRET": "clinic-secret-dev",
    "LOG_LEVEL": "info"
  }
}
